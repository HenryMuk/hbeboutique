        <mxCell id="dtitle" value="DIAGRAMME DE DÉPLOIEMENT — HBE Boutique" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontStyle=1;fontSize=16;align=center;" vertex="1" parent="1"><mxGeometry x="60" y="10" width="1250" height="40" as="geometry" /></mxCell>
        <mxCell id="node1" value="&amp;#171;device&amp;#187;&lt;br&gt;&lt;b&gt;Poste client&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal;&quot;&gt;Navigateur web&lt;/span&gt;" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#EDE7F6;strokeColor=#7E57C2;" vertex="1" parent="1"><mxGeometry x="60" y="140" width="220" height="130" as="geometry" /></mxCell>
        <mxCell id="art2" value="&lt;div style=&quot;text-align:center;font-style:italic;font-size:9px;&quot;&gt;&amp;#171;artifact&amp;#187;&lt;/div&gt;&lt;div style=&quot;text-align:center;font-weight:bold;border-bottom:1px solid #7E57C2;padding-bottom:2px;&quot;&gt;build/ (React SPA)&lt;/div&gt;&lt;div style=&quot;padding:4px 6px;font-size:10px;&quot;&gt;index.html, JS/CSS bundlés&lt;br&gt;servis en HTTPS&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#D1C4E9;strokeColor=#7E57C2;dashed=0;" vertex="1" parent="1"><mxGeometry x="90" y="300" width="160" height="70" as="geometry" /></mxCell>
        <mxCell id="node3" value="&amp;#171;device&amp;#187;&lt;br&gt;&lt;b&gt;Hébergement statique&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal;&quot;&gt;CDN / hébergeur front&lt;br&gt;(Vercel, Netlify, Nginx...)&lt;/span&gt;" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#E1F5FE;strokeColor=#29B6F6;" vertex="1" parent="1"><mxGeometry x="370" y="60" width="260" height="130" as="geometry" /></mxCell>
        <mxCell id="node4" value="&amp;#171;device&amp;#187;&lt;br&gt;&lt;b&gt;Serveur d'application&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal;&quot;&gt;Node.js &amp;gt;= 18 — Express&lt;br&gt;Port 5000 (HTTP/JSON)&lt;/span&gt;" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#E8F5E9;strokeColor=#66BB6A;" vertex="1" parent="1"><mxGeometry x="370" y="260" width="320" height="190" as="geometry" /></mxCell>
        <mxCell id="art5" value="&lt;div style=&quot;text-align:center;font-style:italic;font-size:9px;&quot;&gt;&amp;#171;artifact&amp;#187;&lt;/div&gt;&lt;div style=&quot;text-align:center;font-weight:bold;border-bottom:1px solid #66BB6A;padding-bottom:2px;&quot;&gt;server/src (API REST)&lt;/div&gt;&lt;div style=&quot;padding:4px 6px;font-size:10px;&quot;&gt;routes / controllers / services / repositories&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#C8E6C9;strokeColor=#66BB6A;dashed=0;" vertex="1" parent="1"><mxGeometry x="400" y="340" width="260" height="40" as="geometry" /></mxCell>
        <mxCell id="art6" value="&lt;div style=&quot;text-align:center;font-style:italic;font-size:9px;&quot;&gt;&amp;#171;artifact&amp;#187;&lt;/div&gt;&lt;div style=&quot;text-align:center;font-weight:bold;border-bottom:1px solid #66BB6A;padding-bottom:2px;&quot;&gt;server/uploads/&lt;/div&gt;&lt;div style=&quot;padding:4px 6px;font-size:10px;&quot;&gt;produits/ (public)&lt;br&gt;factures/ (protégé, JWT requis)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#C8E6C9;strokeColor=#66BB6A;dashed=0;" vertex="1" parent="1"><mxGeometry x="400" y="390" width="260" height="50" as="geometry" /></mxCell>
        <mxCell id="node7" value="&amp;#171;device&amp;#187;&lt;br&gt;&lt;b&gt;Serveur de base de données&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal;&quot;&gt;MySQL 8&lt;br&gt;Port 3306&lt;/span&gt;" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#FBE9E7;strokeColor=#FF7043;" vertex="1" parent="1"><mxGeometry x="770" y="260" width="240" height="190" as="geometry" /></mxCell>
        <mxCell id="art8" value="&lt;div style=&quot;text-align:center;font-style:italic;font-size:9px;&quot;&gt;&amp;#171;artifact&amp;#187;&lt;/div&gt;&lt;div style=&quot;text-align:center;font-weight:bold;border-bottom:1px solid #FF7043;padding-bottom:2px;&quot;&gt;Schéma hbeboutique&lt;/div&gt;&lt;div style=&quot;padding:4px 6px;font-size:10px;&quot;&gt;utilisateurs, produits,&lt;br&gt;commandes, commande_lignes,&lt;br&gt;factures, livraisons,&lt;br&gt;tickets_sav, panier_items, ...&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fontSize=10;fillColor=#FFCCBC;strokeColor=#FF7043;dashed=0;" vertex="1" parent="1"><mxGeometry x="795" y="340" width="190" height="90" as="geometry" /></mxCell>
        <mxCell id="node9" value="&amp;#171;device&amp;#187;&lt;br&gt;&lt;b&gt;Serveur SMTP externe&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;font-weight:normal;&quot;&gt;Gmail SMTP&lt;br&gt;(port 465/587)&lt;/span&gt;" style="shape=cube;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;darkOpacity=0.05;size=12;align=center;verticalAlign=top;spacingTop=6;fontSize=12;fillColor=#F5F5F5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="1090" y="260" width="220" height="130" as="geometry" /></mxCell>
        <mxCell id="lnk10" value="HTTPS — récupère le bundle React" style="endArrow=none;startArrow=none;html=1;fontSize=10;dashed=0;strokeColor=#29B6F6;fontColor=#29B6F6;rounded=0;" edge="1" parent="1" source="node1" target="node3"><mxGeometry relative="1" as="geometry" /></mxCell>
